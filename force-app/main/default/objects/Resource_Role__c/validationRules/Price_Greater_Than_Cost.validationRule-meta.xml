<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Price_Greater_Than_Cost</fullName>
    <active>true</active>
    <errorConditionFormula>Price__c &lt; Cost__c</errorConditionFormula>
    <errorDisplayField>Price__c</errorDisplayField>
    <errorMessage>Price must be greater than or equal to Cost</errorMessage>
</ValidationRule>
