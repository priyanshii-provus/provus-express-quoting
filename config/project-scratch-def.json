{
  "orgName": "Provus Express Quoting",
  "edition": "enterprise",
  "language": "en_IN",
  "country": "IN",
  "features": [
    "Communities",
    "ServiceCloud",
    "Einstein1AIPlatform"
  ],
  "settings": {
    "lightningExperienceSettings": {
      "enableS1DesktopEnabled": true
    },
